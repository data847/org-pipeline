# OpenAI API Key
# Required for LLM-based quality checks (vibecode, security, production quality).
# If not set, LLM analysis will be skipped and only static checks will run.
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...your-key-here...

# ── GitHub Token ─────────────────────────────────────────────────────────────
# Required for run_all_repos.py with GitHub (also accepts GH_TOKEN)
# GITHUB_TOKEN=ghp_...your-token-here...

# ── GitLab Token ─────────────────────────────────────────────────────────────
# Required for run_all_repos.py with --platform gitlab (also accepts GL_TOKEN)
# Create at: https://gitlab.com/-/user_settings/personal_access_tokens
# Required scopes: read_api, read_repository
# GITLAB_TOKEN=glpat-...your-token-here...

# GitLab instance URL (for self-hosted GitLab, default: https://gitlab.com)
# GITLAB_URL=https://gitlab.com

# ── Bitbucket Token ───────────────────────────────────────────────────────────
# Required for run_all_repos.py with --platform bitbucket (also accepts BB_TOKEN)
# Create at: https://bitbucket.org/account/settings/app-passwords/
# Required scopes: Account (Read), Repositories (Read), Workspace membership (Read)
# BITBUCKET_TOKEN=...your-app-password-or-api-token-here...
# BITBUCKET_USERNAME=your-bitbucket-username   # for app passwords
# BITBUCKET_EMAIL=you@example.com              # for API tokens (alternative to username)

# ── run_all_repos.py configuration ──────────────────────────────────────────
# All of these are optional — CLI args override env vars.

# Platform to use: github | gitlab | bitbucket (default: github)
# EVAL_PLATFORM=github

# Comma-separated list of orgs/groups to evaluate (default: all accessible)
# EVAL_ORGS=my-org,another-org

# Comma-separated list of orgs to skip
# EVAL_EXCLUDE_ORGS=test-org,sandbox-org

# Comma-separated list of repos to skip (owner/repo format)
# EVAL_EXCLUDE_REPOS=my-org/old-repo,my-org/deprecated-app

# Include personal & collaborator repos (true/false, default: false)
# EVAL_INCLUDE_USER=false

# Include archived repos (true/false, default: false)
# EVAL_INCLUDE_ARCHIVED=false

# Include forked repos (true/false, default: false)
# EVAL_INCLUDE_FORKS=false

# Filter by visibility: all | public | private (default: all)
# EVAL_VISIBILITY=all

# Number of parallel evaluation workers (default: 4)
# EVAL_WORKERS=4

# Output directory for per-repo JSON results (default: eval_results)
# EVAL_OUTPUT_DIR=eval_results

# Path to the evaluator script (default: repo_evaluator.py)
# EVAL_EVALUATOR_SCRIPT=repo_evaluator.py

# Extra flags passed through to repo_evaluator.py
# EVAL_EVALUATOR_ARGS=--skip-f2p --skip-quality-checks
